# Django
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,manejador_usuarios
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING

# PostgreSQL
DB_NAME=usuarios_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres_usuarios
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis (AWS Elasticache in production)
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=300
CUENTA_CLOUD_CACHE_TTL=300
EMPRESA_CACHE_TTL=300

# RabbitMQ (AMQP)
RABBITMQ_URL=amqp://bite:bite_pass@rabbitmq:5672/bite_vhost
RABBITMQ_EXCHANGE=bite_events
RABBITMQ_ROUTING_KEY_PROJECT=proyecto.creado

# Inter-service: manejador_cloud
RESOURCE_SERVICE_URL=http://manejador_cloud:8002
RESOURCE_SERVICE_TIMEOUT=2

# API throttling
API_THROTTLE_ANON=1000/min

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
