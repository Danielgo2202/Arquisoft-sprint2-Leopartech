# Django
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,manejador_seguridad
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING

# PostgreSQL (shared with manejador_autenticacion)
DATABASE_NAME=seguridad_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=postgres_seguridad
DATABASE_PORT=5432

# Auth service (manejador_autenticacion)
AUTH_SERVICE_URL=http://manejador-autenticacion:8004
AUTH_SERVICE_TIMEOUT=2

# Local JWT secret (must match manejador_autenticacion LOCAL_JWT_SECRET)
LOCAL_JWT_SECRET=local-dev-jwt-secret-change-in-production

# Amazon Cognito (leave blank to use local JWT fallback)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1

# Gunicorn
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
