# Django
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,manejador_reportes
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING

# PostgreSQL
DB_NAME=reportes_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres_reportes
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis (Celery result backend + cache)
REDIS_URL=redis://redis:6379/2
REDIS_CACHE_TTL=300
CELERY_RESULT_BACKEND=redis://redis:6379/3

# RabbitMQ (AMQP - Celery broker + event consumer)
RABBITMQ_URL=amqp://bite:bite_pass@rabbitmq:5672/bite_vhost
CELERY_BROKER_URL=amqp://bite:bite_pass@rabbitmq:5672/bite_vhost
RABBITMQ_EXCHANGE=bite_events
RABBITMQ_QUEUE_PROYECTOS=bite.proyectos
RABBITMQ_QUEUE_ANALISIS=bite.analisis
RABBITMQ_QUEUE_REPORTES=bite.reportes

# Celery
CELERY_WORKER_CONCURRENCY=8
CELERY_TASK_SOFT_TIME_LIMIT=120
CELERY_TASK_TIME_LIMIT=180

# Email notification (external provider)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=notificaciones@bite.co

# API throttling
API_THROTTLE_ANON=5000/min

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
