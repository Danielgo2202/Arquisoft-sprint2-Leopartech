# Django
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,manejador_autenticacion
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING

# PostgreSQL (shared with manejador_seguridad)
DATABASE_NAME=seguridad_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=postgres_seguridad
DATABASE_PORT=5432

# Local JWT fallback (used when COGNITO_USER_POOL_ID is NOT set)
# This allows docker compose up to work without AWS credentials
LOCAL_JWT_SECRET=local-dev-jwt-secret-change-in-production
LOCAL_JWT_ACCESS_EXPIRY=3600
LOCAL_JWT_REFRESH_EXPIRY=86400

# Amazon Cognito (leave blank to use local JWT fallback)
# When set, these take priority over local JWT
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1

# Gunicorn
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
