# Django
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,manejador_cloud
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING

# PostgreSQL
DB_NAME=cloud_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres_cloud
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis (AWS Elasticache in production)
REDIS_URL=redis://redis:6379/1
REDIS_CACHE_TTL=600
RECURSO_CACHE_TTL=600
CUENTA_CLOUD_CACHE_TTL=300
PROVEEDOR_CACHE_TTL=3600

# API throttling
API_THROTTLE_ANON=2000/min

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
